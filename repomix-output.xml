    background-color: #f8fafc;
}

.checkbox-card input {
    accent-color: var(--primary-blue);
    cursor: pointer;
    transform: scale(1.1);
}

.checkbox-card span {
    font-size: 0.9rem;
    color: var(--text-dark);
}

/* ============================
   Nota informativa
   ============================ */

.info-box {
    padding: 12px 14px;
    background-color: #f8fafc;
    border: 1px solid var(--border-color);
    border-left: 4px solid var(--accent-blue);
    border-radius: 6px;
    color: var(--text-muted);
    font-size: 0.85rem;
}

/* ============================
   Botones
   ============================ */

.form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    padding-top: 18px;
    border-top: 1px solid var(--border-color);
}

.form-actions a {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.btn-danger-outline {
    background-color: white;
    color: var(--status-red);
    border: 1px solid var(--status-red);
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
}

.btn-danger-outline:hover {
    background-color: #fef2f2;
}

/* ============================
   Responsive básico
   ============================ */

@media (max-width: 800px) {
    .form-row {
        flex-direction: column;
    }

    .radio-grid,
    .checkbox-grid {
        grid-template-columns: 1fr;
    }

    .campanya-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 12px;
    }

    .form-actions {
        flex-direction: column;
    }

    .form-actions button,
    .form-actions a {
        width: 100%;
    }
}

/* ============================
   Listado de campañas
   ============================ */

.campanya-list-wrapper {
    max-width: 1100px;
    margin: 0 auto;
}

.campanya-table-card {
    padding: 0;
    overflow: hidden;
}
/* ============================ */

/*Retoques de la tabla para campañas*/

.modernTable {
    table-layout: fixed;

}

.modernTable th:nth-child(1),
.modernTable td:nth-child(1) {
    width: 12%;
}

.modernTable th:nth-child(2),
.modernTable td:nth-child(2) {
    width: 13%;
}

.modernTable th:nth-child(3),
.modernTable td:nth-child(3) {
    width: 19%;
}

.modernTable th:nth-child(4),
.modernTable td:nth-child(4),
.modernTable th:nth-child(5),
.modernTable td:nth-child(5) {
    width: 12%;
}

.modernTable th:nth-child(6),
.modernTable td:nth-child(6) {
    width: 32%;
}



/* ============================ */



.campanya-list-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 18px;
}

.btn-primary{
    margin: 3px;
}

.btn-outline{
    margin: 3px;
}


.campanya-list-actions a {
    text-decoration: none;
}

.cadena-chip {
    display: inline-block;
    padding: 3px 8px;
    margin: 2px 3px 2px 0;
    border-radius: 999px;
    background-color: #eef2ff;
    color: var(--primary-blue);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.3;
}

.action-link {
    display: inline-flex;
    align-items: center;
    padding: 7px 12px;
