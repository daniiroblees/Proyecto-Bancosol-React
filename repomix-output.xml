@import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600&display=swap');

/* Reset básico para la página de login */
body.auth-page {
    margin: 0;
    padding: 0;
    font-family: 'Public Sans', sans-serif;
    background-color: #f3f4f6; /* Fondo gris muy clarito para contrastar con la tarjeta */
}

/* Contenedor que centra la tarjeta en la pantalla */
.login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    padding: 20px;
    box-sizing: border-box;
}

/* Tarjeta principal blanca */
.login-card {
    width: 100%;
    max-width: 380px;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 32px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    box-sizing: border-box;
}

/* Título */
.login-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1f2937;
    text-align: center;
    margin-top: 0;
    margin-bottom: 24px;
}

/* Formulario */
.login-form {
    display: flex;
    flex-direction: column;
    gap: 16px; /* Espacio entre los grupos del formulario */
}

/* Grupo de Label + Input */
.form-group {
    display: flex;
    flex-direction: column;
}

.form-group label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
    margin-bottom: 4px;
}

.form-group input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
    box-sizing: border-box;
    transition: all 0.2s ease;
}

.form-group input:focus {
    outline: none;
    border-color: #000000;
    box-shadow: 0 0 0 1px #000000;
}

/* Botón de Entrar */
.btn-login {
    width: 100%;
    background-color: #000000;
    color: #ffffff;
    padding: 10px 0;
    border: none;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: 8px;
    cursor: pointer;
    transition: background-color 0.2s ease;
}

.btn-login:hover {
    background-color: #333333;
}

/* Footer de la tarjeta (enlaces) */
.login-footer {
    margin-top: 24px;
    text-align: center;
}

.login-link {
    font-size: 0.75rem;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s;
}

.login-link:hover {
    color: #000000;
}

/* Mensaje de error */
.error-message {
    background-color: #fee2e2;
    color: #b91c1c;
    font-size: 0.85rem;
    padding: 10px;
    border-radius: 4px;
    text-align: center;
    margin-bottom: 16px;
    border: 1px solid #f87171;
}
</file>

<file path="src/styles/coordinadores.css">
@import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;700&display=swap');


/* ============================
   Layout general campañas
   ============================ */

.main-page {
    padding: 25px;
    box-sizing: border-box;
    min-height: calc(100vh - 80px);
}

.campanya-form-wrapper {
    max-width: 900px;
    margin: 0 auto;
}

.campanya-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.campanya-header h1 {
    font-size: 1.4rem;
    margin: 0;
    color: var(--text-dark);
}

.campanya-header p {
    margin: 6px 0 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
}

/* ============================
   Tarjeta del formulario
   ============================ */

.campanya-form-card {
    padding: 25px;
}

.campanya-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.form-section {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.form-section-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--primary-blue);
    margin: 0;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
}

.form-row {
    display: flex;
    gap: 18px;
}

.form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 7px;
}

.form-group label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-dark);
}

.form-group input[type="text"],
.form-group input[type="date"],
.form-group select {
    padding: 10px 12px;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.95rem;
    background-color: white;
    color: var(--text-dark);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
}

.form-group input[type="text"]:focus,
.form-group input[type="date"]:focus,
.form-group select:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(68, 114, 196, 0.12);
}

/* ============================
   Radios tipo campaña
   ============================ */

.radio-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
}

.option-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background-color: #f8fafc;
    cursor: pointer;
    transition: border-color 0.2s, background-color 0.2s, transform 0.1s;
}

.option-card:hover {
    border-color: var(--accent-blue);
    background-color: #f0f7ff;
}

.option-card input {
    accent-color: var(--primary-blue);
    cursor: pointer;
}

.option-card span {
    font-size: 0.9rem;
    color: var(--text-dark);
}

/* ============================
   Checkboxes cadenas
   ============================ */

.checkbox-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
}

.checkbox-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 14px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background-color: white;
    cursor: pointer;
    transition: border-color 0.2s, background-color 0.2s;
}

.checkbox-card:hover {
    border-color: var(--accent-blue);
    background-color: #f8fafc;
}

.checkbox-card input {
    accent-color: var(--primary-blue);
    cursor: pointer;
    transform: scale(1.1);
}

.checkbox-card span {
    font-size: 0.9rem;
    color: var(--text-dark);
}

/* ============================
   Nota informativa
   ============================ */

.info-box {
    padding: 12px 14px;
    background-color: #f8fafc;
    border: 1px solid var(--border-color);
    border-left: 4px solid var(--accent-blue);
    border-radius: 6px;
    color: var(--text-muted);
    font-size: 0.85rem;
}

/* ============================
   Botones
   ============================ */

.form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    padding-top: 18px;
    border-top: 1px solid var(--border-color);
}

.form-actions a {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.btn-danger-outline {
    background-color: white;
    color: var(--status-red);
    border: 1px solid var(--status-red);
    padding: 10px 20px;
    border-radius: 6px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
}

.btn-danger-outline:hover {
    background-color: #fef2f2;
}

/* ============================
   Responsive básico
   ============================ */

@media (max-width: 800px) {
    .form-row {
        flex-direction: column;
    }

    .radio-grid,
    .checkbox-grid {
        grid-template-columns: 1fr;
    }

    .campanya-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 12px;
    }

    .form-actions {
        flex-direction: column;
    }

    .form-actions button,
    .form-actions a {
        width: 100%;
    }
}

/* ============================
   Listado de campañas
   ============================ */

.campanya-list-wrapper {
    max-width: 1100px;
    margin: 0 auto;
}

.coordinadores-list-wrapper {
    max-width: none;
}

.campanya-table-card {
    padding: 0;
    overflow: hidden;
}

.coordinadores-table-card {
    overflow-x: auto;
    overflow-y: hidden;
}
/* ============================ */

/*Retoques de la tabla para campañas*/

.modernTable {
    table-layout: fixed;

}

.modernTable th:nth-child(1),
.modernTable td:nth-child(1) {
    width: 12%;
}

.modernTable th:nth-child(2),
.modernTable td:nth-child(2) {
    width: 13%;
}

.modernTable th:nth-child(3),
.modernTable td:nth-child(3) {
    width: 19%;
}

.modernTable th:nth-child(4),
.modernTable td:nth-child(4),
.modernTable th:nth-child(5),
.modernTable td:nth-child(5) {
    width: 12%;
}

.modernTable th:nth-child(6),
.modernTable td:nth-child(6) {
    width: 32%;
}



/* ============================ */



.coordinadores-table {
    min-width: 0;
    width: 100%;
    table-layout: fixed;
}

.coordinadores-table th:nth-child(1),
.coordinadores-table td:nth-child(1) {
    width: 7%;
}

.coordinadores-table th:nth-child(2),
.coordinadores-table td:nth-child(2) {
    width: 15%;
}

.coordinadores-table th:nth-child(3),
.coordinadores-table td:nth-child(3) {
    width: 18%;
}

.coordinadores-table th:nth-child(4),
.coordinadores-table td:nth-child(4) {
    width: 15%;
}

.coordinadores-table th:nth-child(5),
.coordinadores-table td:nth-child(5) {
    width: 10%;
}

.coordinadores-table th:nth-child(6),
.coordinadores-table td:nth-child(6) {
    width: 18%;
}

.coordinadores-table th:nth-child(7),
.coordinadores-table td:nth-child(7) {
    width: 7%;
}

.coordinadores-table th:nth-child(8),
.coordinadores-table td:nth-child(8) {
    width: 10%;
}

.campanya-list-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 18px;
}

.btn-primary{
    margin: 3px;
}

.btn-outline{
    margin: 3px;
}


.campanya-list-actions a {
    text-decoration: none;
}

.cadena-chip {
    display: inline-block;
    padding: 3px 8px;
    margin: 2px 3px 2px 0;
    border-radius: 999px;
    background-color: #eef2ff;
    color: var(--primary-blue);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.3;
}

.action-link {
    display: inline-flex;
    align-items: center;
    padding: 7px 12px;
    border-radius: 6px;
    background-color: #f8fafc;
    border: 1px solid var(--border-color);
}

.action-link:hover {
    background-color: #f0f7ff;
    text-decoration: none;
}

/* Botón editar campaña */
.edit-campanya-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;

    padding: 8px 14px;
    border-radius: 10px;

    background-color: #eaf2ff;
    color: #123c69;
    font-weight: 700;
    font-size: 14px;

    text-decoration: none;
    border: 1px solid #c7dbf5;

    transition: background-color 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease;
}

.edit-campanya-btn:hover {
    background-color: #d9eaff;
    color: #0b2d52;
    text-decoration: none;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(18, 60, 105, 0.15);
}

.edit-campanya-btn:active {
    transform: translateY(0);
    box-shadow: none;
}

.edit-campanya-icon {
    font-size: 14px;
    line-height: 1;
}

/* ============================
   Select tipo campaña
   ============================ */

.campanya-select {
    width: 100%;
    height: 46px;
    box-sizing: border-box;
    padding: 0 16px;

    border: 1px solid var(--border-color);
    border-radius: 8px;

    background-color: white;
    color: var(--text-dark);

    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;

    cursor: pointer;
    outline: none;

    transition: border-color 0.2s ease,
    box-shadow 0.2s ease,
    background-color 0.2s ease;
}

.campanya-select:hover {
    border-color: var(--accent-blue);
    background-color: #f8fafc;
}

.campanya-select:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(68, 114, 196, 0.12);
}

.btn-nueva-cadena {
    background-color: var(--primary-blue);
    color: white;
    border: none;

    padding: 10px 20px;
    border-radius: 6px;

    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.delete-cdn-check{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;

    padding: 8px 14px;
    border-radius: 10px;

    background-color: #eaf2ff;
    color: #123c69;
    font-weight: 700;
    font-size: 14px;

    text-decoration: none;
    border: 1px solid #c7dbf5;

    transition: background-color 0.2s ease,
    transform 0.2s ease,
    box-shadow 0.2s ease;
}

/* ============================
   Eliminación de campañas
   ============================ */

.campanya-row-actions {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.campanya-delete-checkbox {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: #ef4444;
}

.campanya-row-selected td {
    background-color: #fee2e2 !important;
    color: #7f1d1d;
}

.campanya-row-selected td:first-child {
    border-left: 4px solid #ef4444;
}

.campanya-row-selected .edit-campanya-btn {
    background-color: #fecaca;
    color: #991b1b;
    border-color: #ef4444;
}

.btn-outline-danger:hover {
    background-color: #fee2e2 !important;
    color: #b91c1c !important;
    border-color: #dc2626 !important;
}
